# ─────────────────────────────────────────────────
#   SlimURL — Environment Variables
#   Copy this file to .env and fill in the values
#   cp .env.example .env
# ─────────────────────────────────────────────────

# ── Database ──────────────────────────────────────
# MongoDB Atlas connection string (recommended for production)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/urlShortner?retryWrites=true&w=majority

# Database name
DB_NAME=urlShortner

# ── Server ────────────────────────────────────────
# Port the Express server will listen on
PORT=8000

# Application environment: development | production
NODE_ENV=production
